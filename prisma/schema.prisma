generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id          String   @id @default(cuid())
  code        String   @unique // Admin code
  name        String
  positions   String
  
  shooting    Int      @default(50)
  passing     Int      @default(50)
  dribbling   Int      @default(50)
  defending   Int      @default(50)
  physical    Int      @default(50)
  pace        Int      @default(50)
  
  rating      Float    @default(50.0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matches     MatchPlayer[]
  votesGiven  Vote[] @relation("Voter")
  votesReceived Vote[] @relation("Target")
  councilVotesGiven  CouncilVote[] @relation("CouncilVoter")
  councilVotesReceived CouncilVote[] @relation("CouncilTarget")
}

model CouncilVote {
  id        String @id @default(cuid())
  voterId   String
  targetId  String
  
  shooting    Int
  passing     Int
  dribbling   Int
  defending   Int
  physical    Int
  pace        Int
  rating      Float

  voter     Player @relation("CouncilVoter", fields: [voterId], references: [id])
  target    Player @relation("CouncilTarget", fields: [targetId], references: [id])

  createdAt   DateTime @default(now())

  @@unique([voterId, targetId])
}

model Match {
  id          String   @id @default(cuid())
  date        DateTime
  status      String   @default("PENDING")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  players     MatchPlayer[]
  votes       Vote[]
}

model MatchPlayer {
  id        String @id @default(cuid())
  matchId   String
  playerId  String
  team      String
  
  match     Match  @relation(fields: [matchId], references: [id])
  player    Player @relation(fields: [playerId], references: [id])

  @@unique([matchId, playerId])
}

model Vote {
  id        String @id @default(cuid())
  matchId   String
  voterId   String
  targetId  String
  rating    Int
  
  match     Match  @relation(fields: [matchId], references: [id])
  voter     Player @relation("Voter", fields: [voterId], references: [id])
  target    Player @relation("Target", fields: [targetId], references: [id])

  @@unique([matchId, voterId, targetId])
}
